{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "rvc-ui",
  "version": "0.1.0",
  "identifier": "tech.nijino.rvc.rs",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "rvc-ui",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "frameworks": [
        "/opt/homebrew/lib/libtorch.dylib",
        "/opt/homebrew/lib/libtorch_cpu.dylib",
        "/opt/homebrew/lib/libc10.dylib",
        "/opt/homebrew/anaconda3/lib/libc++.1.dylib",
        "/opt/homebrew/anaconda3/lib/libiconv.2.dylib"
      ]
    }
  }
}
